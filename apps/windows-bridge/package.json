    "pino": "10.3.1",
    "ws": "8.21.1",
    "zod": "4.4.3",
    "loudness": "0.4.2",
    "obs-websocket-js": "5.0.8",
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "@types/ws": "8.18.1"
  }
