{
  "name": "@cinder/core",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run --coverage.enabled=false",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "eval": "tsx src/eval/run.ts",
    "cli": "node dist/cli.js"
  },
  "dependencies": {
    "@cinder/shared": "2.0.0",
    "@discordjs/voice": "0.19.2",
    "@fastify/cookie": "11.0.2",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/static": "10.1.0",
    "discord.js": "14.27.0",
    "dotenv": "17.4.2",
    "fastify": "5.10.0",
    "nanoid": "5.1.5",
    "openai": "6.47.0",
    "opusscript": "0.0.8",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "prism-media": "1.3.5",
    "ws": "8.21.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/pg": "8.15.6",
    "@types/ws": "8.18.1"
  }
}
