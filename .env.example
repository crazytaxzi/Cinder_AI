# Core native service
NODE_ENV=production
LOG_LEVEL=info
HOST=127.0.0.1
PORT=3100
DATABASE_URL=postgresql://cinder:CHANGE_ME@127.0.0.1:55432/cinder
DATABASE_SSL=false
MIGRATIONS_DIR=/opt/cinder/current/migrations

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=none
OPENAI_TIMEOUT_MS=120000
OPENAI_MAX_RETRIES=2
STARTUP_SELF_TEST=true
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
CINDER_SOCIAL_MODEL=gpt-5.4-nano
CINDER_VOICE_SOCIAL_MODEL=gpt-5.4-nano
CINDER_VOICE_CLOUD_TRANSCRIPTION=true
CINDER_VOICE_CLOUD_STT_USD_PER_MINUTE=0.003
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=cedar
OPENAI_TTS_INSTRUCTIONS=A small mischievous imp with a lightly gravelly, raspy texture: smug, playful, crisp, and emotionally expressive. Infer the emotional subtext of each line and vary timing, emphasis, energy, and pauses naturally. Let jokes sound amused, warnings serious, conspiratorial lines intimate, and excitement genuinely animated. Keep the rasp subtle so every word stays clear. Never sound corporate, flat, or monotone.
CINDER_VOICE_CLOUD_TTS=true
CINDER_VOICE_CLOUD_TTS_USD_PER_MINUTE=0.015
CINDER_VOICE_SPEED=0.468
CINDER_VOICE_PITCH=0.538055352
LOCAL_PIPER_PYTHON=/opt/cinder/local-voice/piper-venv/bin/python
LOCAL_PIPER_MODEL=/opt/cinder/local-voice/models/en_US-ryan-medium.onnx
LOCAL_PIPER_WORKER=/opt/cinder/current/scripts/piper-worker.py
LOCAL_WHISPER_BINARY=/opt/cinder/local-voice/whisper.cpp/build/bin/whisper-cli
LOCAL_WHISPER_MODEL=/opt/cinder/local-voice/models/ggml-tiny.en.bin
LOCAL_WHISPER_THREADS=2

# Discord
DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
CINDER_OWNER_DISCORD_ID=
DEFAULT_MODERATOR_ROLE_NAME=Moderator
DEFAULT_VOICE_JOIN_ROLE_NAME=Moderator
DISCORD_VOICE_IDLE_MINUTES=20
DISCORD_VOICE_MAX_UTTERANCE_SECONDS=45
DISCORD_VOICE_SILENCE_PADDING_FRAMES=20
DISCORD_VOICE_BARGE_IN_GRACE_MS=450

# Twitch
TWITCH_ENABLED=false
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_ACCESS_TOKEN=
TWITCH_BOT_REFRESH_TOKEN=
TWITCH_BOT_USER_ID=
TWITCH_BROADCASTER_ACCESS_TOKEN=
TWITCH_BROADCASTER_REFRESH_TOKEN=
TWITCH_BROADCASTER_ID=
TWITCH_CHAT_BATCH_MS=1200
TWITCH_MAX_BATCH_MESSAGES=25

# Windows bridge
BRIDGE_ENABLED=false
BRIDGE_TOKEN=
BRIDGE_PORT=3010
BRIDGE_COMMAND_TTL_SECONDS=90
BRIDGE_PUBLISH_ADDRESS=127.0.0.1

# Cinder context
SCENE_RECENT_EVENT_LIMIT=12
SCENE_MEMORY_LIMIT=8
SCENE_RECENT_ACTION_LIMIT=8
CINDER_SOCIAL_CONTEXT_EVENT_LIMIT=10
CINDER_SOCIAL_MAX_REPLY_CHARACTERS=500
CINDER_VOICE_CONTEXT_EVENT_LIMIT=8
CINDER_VOICE_MAX_REPLY_CHARACTERS=220
CINDER_VOICE_SPEECH_END_MS=550
CINDER_MAX_TOOL_ROUNDS=3
CINDER_MAX_OUTPUT_TOKENS=600
CINDER_MAX_REPLY_CHARACTERS=900
CINDER_PROFILE_PATH=/opt/cinder/current/config/cinder-profile.md
EVENT_RETENTION_DAYS=30
ACTION_RETENTION_DAYS=365
EXTERNAL_EVENT_RETENTION_DAYS=14

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_ADMIN_PASSWORD_HASH=
DASHBOARD_SESSION_SECRET=
DASHBOARD_SESSION_TTL_HOURS=72
CINDER_INTERNAL_CONTROL_TOKEN=

# Native PostgreSQL metadata
POSTGRES_DB=cinder
POSTGRES_USER=cinder
POSTGRES_PASSWORD=CHANGE_ME
CINDER_PG_MAJOR=
CINDER_PG_CLUSTER=cinder
CINDER_PG_PORT=55432
